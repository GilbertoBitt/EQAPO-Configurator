<ui:FluentWindow x:Class="EQAPO_Configurator.HeadphoneSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Headphone Setup"
        Width="700" Height="600"
        MinWidth="500" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ExtendsContentIntoTitleBar="True"
        Background="{DynamicResource ApplicationBackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <ui:TitleBar Grid.Row="0" Title="Headphone Setup" ShowMaximize="False" />

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,8">
            <StackPanel MaxWidth="600" HorizontalAlignment="Center">

                <!-- Device Detection -->
                <TextBlock Text="Detected Audio Device"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12" />

                <ui:CardControl Margin="0,0,0,8" Padding="12">
                    <ui:CardControl.Header>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                            <TextBlock Text="Device"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                            <TextBlock x:Name="DetectedDeviceText"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <ui:Button Grid.Column="1"
                                       Content="Device selector"
                                       Click="OnOpenDeviceSelector"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </ui:CardControl.Header>
                </ui:CardControl>

                <ui:CardControl Margin="0,0,0,16" Padding="12">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="Audio Mode"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                            <TextBlock x:Name="DetectedModeText"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </ui:CardControl.Header>
                </ui:CardControl>

                <ui:CardControl Margin="0,0,0,16" Padding="12">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="Active Headphone Base"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                            <TextBlock x:Name="ActiveHeadphoneLayerText"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            <TextBlock Text="Applied globally as Layer 1. Game and application profiles add Layer 2 fine-tuning automatically."
                                       FontSize="10"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                        </StackPanel>
                    </ui:CardControl.Header>
                </ui:CardControl>

                <!-- Divider -->
                <Separator Margin="0,0,0,16"
                           Background="{DynamicResource CardStrokeColorDefaultBrush}" />

                <!-- Headphone Search -->
                <TextBlock Text="Find Headphone EQ Profile"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4" />

                <TextBlock Text="Search once to find existing AutoEQ profiles or generate one with the local Python AutoEQ library"
                           FontSize="11"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,0,0,12"
                           TextWrapping="Wrap" />

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:TextBox Grid.Column="0"
                                x:Name="HeadphoneSearchBox"
                                PlaceholderText="e.g. SteelSeries Arctis Nova Pro, HyperX Cloud, Sennheiser HD 600..."
                                Icon="{ui:SymbolIcon Search24}"
                                TextChanged="OnSearchTextChanged" />
                    <ui:Button Grid.Column="1"
                              x:Name="SearchBtn"
                              Content="Search"
                              Icon="{ui:SymbolIcon Search24}"
                              Appearance="Primary"
                              Click="OnSearchClick"
                              IsEnabled="False"
                              Margin="8,0,0,0" />
                </Grid>

                <!-- Search Results -->
                <ListBox x:Name="SearchResultsList"
                         MaxHeight="200"
                         Margin="0,0,0,12"
                         BorderThickness="1"
                         BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                         Visibility="Collapsed">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10,8" CornerRadius="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold" />
                                        <TextBlock FontSize="10"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                            <Run Text="{Binding Detail}" />
                                        </TextBlock>
                                    </StackPanel>
                                    <ui:Button Grid.Column="1"
                                               Content="{Binding ActionLabel}"
                                               Icon="{ui:SymbolIcon ArrowDownload24}"
                                               Appearance="Transparent"
                                               Padding="8"
                                               ToolTip="Download profile"
                                               Tag="{Binding}"
                                               Click="OnUseUnifiedSearchResult" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Loading indicator -->
                <StackPanel x:Name="SearchLoading"
                            Orientation="Horizontal"
                            Visibility="Collapsed"
                            Margin="0,8,0,12">
                    <ProgressBar Width="16" Height="16" Margin="0,0,8,0"
                                 IsIndeterminate="True" />
                    <TextBlock Text="Searching..."
                               FontSize="11"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <!-- Downloaded Profile Preview -->
                <StackPanel x:Name="ProfilePreviewPanel" Visibility="Collapsed">
                    <TextBlock Text="Downloaded Profile"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8" />

                    <ui:CardControl Margin="0,0,0,8" Padding="12">
                        <ui:CardControl.Header>
                            <StackPanel>
                                <TextBlock FontSize="12"
                                           FontWeight="SemiBold">
                                    <Run Text="Headphone: " />
                                    <Run x:Name="ProfileHeadphoneName" />
                                </TextBlock>
                                <TextBlock FontSize="11"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                    <Run Text="Filters: " />
                                    <Run x:Name="ProfileFilterCount" />
                                    <Run Text=" • Preamp: " />
                                    <Run x:Name="ProfilePreamp" />
                                </TextBlock>
                            </StackPanel>
                        </ui:CardControl.Header>
                    </ui:CardControl>

                    <ScrollViewer MaxHeight="150" VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="ProfileFiltersPreview"
                                   FontSize="10"
                                   FontFamily="Consolas"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                   Padding="12,8"
                                   Margin="0,0,0,12"
                                   TextWrapping="Wrap" />
                    </ScrollViewer>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <ui:Button Content="Export to EqualizerAPO"
                                   Icon="{ui:SymbolIcon Save24}"
                                   Appearance="Primary"
                                   Click="OnExportProfile"
                                   Margin="0,0,8,0" />
                        <ui:Button Content="Apply Again"
                                   Icon="{ui:SymbolIcon Checkmark24}"
                                   Appearance="Secondary"
                                   Click="OnUseAsBaseLayer" />
                    </StackPanel>
                </StackPanel>

                <!-- Python AutoEQ Status -->
                <Separator Margin="0,16,0,16"
                           Background="{DynamicResource CardStrokeColorDefaultBrush}" />

                <TextBlock Text="Python AutoEQ Generator"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4" />

                <TextBlock Text="Python generation results are included automatically in the search above when available"
                           FontSize="11"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,0,0,8"
                           TextWrapping="Wrap" />

                <ui:CardControl x:Name="PythonStatusCard" Margin="0,0,0,8" Padding="12">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock FontSize="12" FontWeight="SemiBold">
                                <Run Text="Python: " />
                                <Run x:Name="PythonStatusText" Text="Checking..." />
                            </TextBlock>
                            <TextBlock x:Name="PythonErrorText"
                                       FontSize="10"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                    </ui:CardControl.Header>
                </ui:CardControl>

                <ProgressBar x:Name="PythonProgress"
                             IsIndeterminate="True"
                             Visibility="Collapsed"
                             Margin="0,0,0,8"
                             Height="4" />

                <!-- Local Profiles -->
                <Separator Margin="0,16,0,16"
                           Background="{DynamicResource CardStrokeColorDefaultBrush}" />

                <TextBlock Text="Saved Headphone Profiles"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12" />

                <ItemsControl x:Name="LocalProfilesPanel">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ui:CardControl Margin="0,0,0,6" Padding="10">
                                <ui:CardControl.Header>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <ui:SymbolIcon Grid.Column="0"
                                                       Symbol="Checkmark24"
                                                       FontSize="14"
                                                       Foreground="{DynamicResource SystemAccentBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,8,0">
                                            <ui:SymbolIcon.Style>
                                                <Style TargetType="ui:SymbolIcon">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ui:SymbolIcon.Style>
                                        </ui:SymbolIcon>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Name}"
                                                   FontSize="12"
                                                   VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                                            <ui:Button Content="Select"
                                                       Icon="{ui:SymbolIcon Checkmark24}"
                                                       Appearance="Primary"
                                                       Click="OnSelectLocalProfile"
                                                       Tag="{Binding Name}"
                                                       Padding="8,4"
                                                       Margin="0,0,4,0"
                                                       ToolTip="Use this profile as the active headphone base layer" />
                                            <ui:Button Icon="{ui:SymbolIcon Delete24}"
                                                       Appearance="Danger"
                                                       Click="OnDeleteLocalProfile"
                                                       Tag="{Binding Name}"
                                                       Padding="4"
                                                       Margin="4,0,0,0" />
                                        </StackPanel>
                                    </Grid>
                                </ui:CardControl.Header>
                            </ui:CardControl>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- Bottom bar -->
        <Border Grid.Row="2"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button Content="Open AutoEQ Website"
                           Icon="{ui:SymbolIcon Globe24}"
                           Click="OnOpenAutoEq"
                           Margin="0,0,8,0" />
                <ui:Button Content="Close"
                           Appearance="Secondary"
                           Click="OnClose" />
            </StackPanel>
        </Border>

        <ui:SnackbarPresenter Grid.Row="1" x:Name="SnackbarPresenter" />
    </Grid>
</ui:FluentWindow>
