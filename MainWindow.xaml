<ui:FluentWindow x:Class="EQAPO_Configurator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="EQAPO Configurator"
        Width="1200" Height="750"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        Background="{DynamicResource ApplicationBackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <ui:TitleBar Grid.Row="0" Title="EQAPO Configurator" ShowMaximize="False">
            <ui:TitleBar.Header>
                <StackPanel Orientation="Horizontal" Margin="0,0,10,0">
                    <ui:Button Icon="{ui:SymbolIcon Headphones24}"
                               ToolTip="Headphone Setup"
                               Click="OnHeadphoneSetup"
                               Appearance="Transparent"
                               Padding="8,4" />
                    <ui:Button Icon="{ui:SymbolIcon Settings24}"
                               ToolTip="Settings"
                               Click="OnSettings"
                               Appearance="Transparent"
                               Padding="8,4" />
                </StackPanel>
            </ui:TitleBar.Header>
        </ui:TitleBar>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" MinWidth="200" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left Sidebar -->
            <Border Grid.Column="0"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Nav Header -->
                    <TextBlock Grid.Row="0"
                               Text="Navigation"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Margin="16,12,16,8" />

                    <!-- Nav Items -->
                    <StackPanel Grid.Row="1">
                        <ui:Button x:Name="NavProfiles"
                                   Content="  Profiles"
                                   Icon="{ui:SymbolIcon Game24}"
                                   Appearance="Primary"
                                   Click="OnNavProfiles"
                                   HorizontalAlignment="Stretch"
                                   HorizontalContentAlignment="Left"
                                   Margin="8,0,8,4"
                                   Padding="12,8" />
                        <ui:Button x:Name="NavEqualizer"
                                   Content="  Equalizer"
                                   Icon="{ui:SymbolIcon HeadphonesSoundWave24}"
                                   Appearance="Transparent"
                                   Click="OnNavEqualizer"
                                   HorizontalAlignment="Stretch"
                                   HorizontalContentAlignment="Left"
                                   Margin="8,0,8,4"
                                   Padding="12,8" />
                        <ui:Button x:Name="NavDevice"
                                   Content="  Device Info"
                                   Icon="{ui:SymbolIcon DesktopSpeaker24}"
                                   Appearance="Transparent"
                                   Click="OnNavDevice"
                                   HorizontalAlignment="Stretch"
                                   HorizontalContentAlignment="Left"
                                   Margin="8,0,8,4"
                                   Padding="12,8" />
                    </StackPanel>

                    <!-- Search -->
                    <ui:TextBox Grid.Row="2"
                                x:Name="SearchBox"
                                PlaceholderText="Search profiles..."
                                Icon="{ui:SymbolIcon Search24}"
                                Margin="8,8,8,4"
                                TextChanged="OnSearchChanged" />

                    <!-- Add Button -->
                    <ui:Button Grid.Row="3"
                              x:Name="AddGameBtn"
                              Content="Add Game"
                              Icon="{ui:SymbolIcon Add24}"
                              Appearance="Primary"
                              Click="OnAddGame"
                              Margin="8,4,8,8"
                              HorizontalAlignment="Stretch" />

                    <!-- Profile List -->
                    <ListBox x:Name="ProfileList"
                             Grid.Row="3"
                             SelectionChanged="OnProfileSelected"
                             BorderThickness="0"
                             Background="Transparent"
                             Margin="0,48,0,0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12,10"
                                        Background="Transparent"
                                        CornerRadius="6"
                                        Margin="4,2">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding IconEmoji}"
                                                   FontSize="18"
                                                   Margin="0,0,10,0"
                                                   VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                            <TextBlock Text="{Binding GenreDisplay}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       Margin="0,2,0,0" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="2"
                                                   Text="✓"
                                                   FontSize="14"
                                                   x:Name="ActiveIcon"
                                                   Foreground="{DynamicResource SystemAccentColor}"
                                                   Visibility="Collapsed"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Right: Content Area -->
            <Border Grid.Column="1"
                    Background="{DynamicResource ApplicationBackgroundBrush}"
                    Padding="24,16">
                <Grid>
                    <!-- Profiles Page -->
                    <Grid x:Name="ProfilesPage" Visibility="Visible">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- No Selection State -->
                        <StackPanel x:Name="NoSelectionPanel"
                                    Grid.Row="0"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center">
                            <TextBlock Text="🎧"
                                       FontSize="48"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Select a Game Profile"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       Margin="0,12,0,4" />
                            <TextBlock Text="Choose a profile from the left panel to configure EQ settings"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>

                        <!-- Profile Detail View -->
                        <Grid x:Name="ProfileDetailPanel"
                              Grid.Row="0"
                              Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Header -->
                            <Grid Grid.Row="0" Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock x:Name="ProfileTitle"
                                               FontSize="22"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                    <TextBlock x:Name="ProfileSubtitle"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <ui:Button x:Name="ActivateBtn"
                                              Content="Activate"
                                              Icon="{ui:SymbolIcon Play24}"
                                              Appearance="Primary"
                                              Click="OnActivateProfile"
                                              Margin="0,0,8,0" />
                                    <ui:Button x:Name="DeactivateBtn"
                                              Content="Deactivate"
                                              Icon="{ui:SymbolIcon Stop24}"
                                              Appearance="Secondary"
                                              Click="OnDeactivateProfile"
                                              Visibility="Collapsed"
                                              Margin="0,0,8,0" />
                                    <ui:Button x:Name="DeleteBtn"
                                              Icon="{ui:SymbolIcon Delete24}"
                                              Appearance="Danger"
                                              Click="OnDeleteProfile" />
                                </StackPanel>
                            </Grid>

                            <!-- In-Game Tips Card -->
                            <ui:CardControl Grid.Row="1" Margin="0,0,0,12">
                                <ui:CardControl.Header>
                                    <StackPanel>
                                        <TextBlock Text="In-Game Audio Settings"
                                                   FontSize="13"
                                                   FontWeight="SemiBold" />
                                        <TextBlock x:Name="InGameTipsText"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,4,0,0" />
                                    </StackPanel>
                                </ui:CardControl.Header>
                            </ui:CardControl>

                            <!-- EQ Sliders -->
                            <ScrollViewer Grid.Row="2"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl x:Name="SoundCategoriesPanel">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <ui:CardControl Margin="0,0,0,8" Padding="8">
                                                <ui:CardControl.Header>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="80" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0"
                                                                   Text="{Binding Icon}"
                                                                   FontSize="18"
                                                                   VerticalAlignment="Center"
                                                                   Margin="0,0,10,0" />
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Name}"
                                                                       FontSize="12"
                                                                       FontWeight="SemiBold" />
                                                            <TextBlock Text="{Binding Description}"
                                                                       FontSize="10"
                                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                       TextTrimming="CharacterEllipsis" />
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="2"
                                                                   x:Name="SliderValueText"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"
                                                                   HorizontalAlignment="Right"
                                                                   VerticalAlignment="Center"
                                                                   MinWidth="50"
                                                                   TextAlignment="Right" />
                                                    </Grid>
                                                </ui:CardControl.Header>
                                                <Slider Minimum="-12"
                                                        Maximum="12"
                                                        Value="{Binding SliderValue}"
                                                        Width="200"
                                                        TickFrequency="1"
                                                        IsSnapToTickEnabled="True"
                                                        VerticalAlignment="Center" />
                                            </ui:CardControl>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <!-- Preamp -->
                            <ui:CardControl Grid.Row="3" Margin="0,8,0,0" Padding="8">
                                <ui:CardControl.Header>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="80" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="Preamp"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1"
                                                   Text="Master volume before EQ — prevents clipping"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="10,0,0,0" />
                                        <TextBlock Grid.Column="2"
                                                   x:Name="PreampValueText"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   MinWidth="50"
                                                   TextAlignment="Right" />
                                    </Grid>
                                </ui:CardControl.Header>
                                <Slider x:Name="PreampSlider"
                                        Minimum="-12"
                                        Maximum="0"
                                        Value="-6"
                                        Width="200"
                                        TickFrequency="0.5"
                                        IsSnapToTickEnabled="True"
                                        ValueChanged="OnPreampChanged"
                                        VerticalAlignment="Center" />
                            </ui:CardControl>
                        </Grid>
                    </Grid>

                    <!-- Equalizer Page -->
                    <Grid x:Name="EqualizerPage" Visibility="Collapsed">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="🎚️"
                                       FontSize="48"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Equalizer View"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       Margin="0,12,0,4" />
                            <TextBlock Text="Select a profile to see detailed EQ configuration"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Grid>

                    <!-- Device Info Page -->
                    <Grid x:Name="DevicePage" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel MaxWidth="600" HorizontalAlignment="Center">
                                <TextBlock Text="Audio Device"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Margin="0,0,0,16" />

                                <ui:CardControl Margin="0,0,0,8" Padding="12">
                                    <ui:CardControl.Header>
                                        <StackPanel>
                                            <TextBlock Text="Detected Device"
                                                       FontSize="12"
                                                       FontWeight="SemiBold" />
                                            <TextBlock x:Name="DeviceNameText"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                    </ui:CardControl.Header>
                                </ui:CardControl>

                                <ui:CardControl Margin="0,0,0,8" Padding="12">
                                    <ui:CardControl.Header>
                                        <StackPanel>
                                            <TextBlock Text="Audio Mode"
                                                       FontSize="12"
                                                       FontWeight="SemiBold" />
                                            <TextBlock x:Name="AudioModeText"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                    </ui:CardControl.Header>
                                </ui:CardControl>

                                <TextBlock Text="Configuration Tips"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Margin="0,20,0,12" />

                                <ItemsControl x:Name="DeviceTipsPanel">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <ui:CardControl Margin="0,0,0,6" Padding="10">
                                                <ui:CardControl.Header>
                                                    <TextBlock Text="{Binding}"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                               TextWrapping="Wrap" />
                                                </ui:CardControl.Header>
                                            </ui:CardControl>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>

            <!-- Status Bar -->
            <Border Grid.Column="0"
                    Grid.ColumnSpan="2"
                    VerticalAlignment="Bottom"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="12,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Ellipse Width="8" Height="8"
                                 Fill="{DynamicResource SystemAccentColor}"
                                 Margin="0,0,8,0"
                                 VerticalAlignment="Center" />
                        <TextBlock x:Name="StatusLabel"
                                   Text="Ready"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Grid.Column="2"
                               x:Name="ActiveProfileLabel"
                               Text=""
                               FontSize="11"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                               VerticalAlignment="Center" />
                </Grid>
            </Border>

            <ui:SnackbarPresenter Grid.Row="1" x:Name="SnackbarPresenter" />
        </Grid>
    </Grid>
</ui:FluentWindow>
