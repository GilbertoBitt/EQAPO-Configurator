<ui:FluentWindow x:Class="EQAPO_Configurator.Controls.ClipReviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:controls="clr-namespace:EQAPO_Configurator.Controls"
        Title="Clip Review" Width="900" Height="600"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ApplicationBackgroundBrush}">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <ui:SymbolIcon Symbol="ChevronLeft24" Margin="0,0,6,0" VerticalAlignment="Center"/>
                <TextBlock Text="CLIP REVIEW" FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock Grid.Column="2" x:Name="ClipInfoText" Text="" FontSize="11"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" VerticalAlignment="Center"/>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock x:Name="CurrentTimeText" Text="0:00" FontSize="11"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
            </StackPanel>

            <Slider Grid.Column="1" x:Name="TimelineSlider" Minimum="0" Maximum="100"
                    ValueChanged="TimelineSlider_ValueChanged"
                    VerticalAlignment="Center" Margin="0,0,8,0"/>

            <TextBlock Grid.Column="2" x:Name="DurationText" Text="0:00" FontSize="11"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="4"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <controls:SpectrumAnalyzer Grid.Row="0" x:Name="ReplaySpectrum" ShowEqOverlay="True"/>

            <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch"
                          Background="{DynamicResource ControlStrongStrokeColorDefaultBrush}"/>

            <controls:ParametricEqEditor Grid.Row="2" x:Name="EqEditor"/>
        </Grid>

        <Grid Grid.Row="3" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <ui:Button x:Name="PlayButton" Content="&#9654;" Width="36" Height="36"
                           Click="PlayButton_Click"
                           Margin="0,0,8,0"
                           Appearance="Primary"/>
                <ui:Button x:Name="PauseButton" Content="&#9646;&#9646;" Width="36" Height="36"
                           Click="PauseButton_Click"
                           Margin="0,0,8,0"
                           IsEnabled="False"/>
                <ui:Button x:Name="StopButton" Content="&#9632;" Width="36" Height="36"
                           Click="StopButton_Click"
                           IsEnabled="False"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <TextBlock Text="Playback EQ affects spectrum view" FontSize="10"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                <ui:Button x:Name="ExportButton" Content="Export Clip" Click="ExportButton_Click"
                           Appearance="Secondary"/>
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
