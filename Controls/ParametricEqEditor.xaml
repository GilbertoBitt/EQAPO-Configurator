<UserControl x:Class="EQAPO_Configurator.Controls.ParametricEqEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             MinHeight="400">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Top: Toolbar -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <ui:Button Content="Import EQ" Icon="{ui:SymbolIcon ArrowDownload24}" Click="OnImport" Margin="0,0,8,0" Padding="10,6" />
                <ui:Button Content="Export EQ" Icon="{ui:SymbolIcon ArrowUpload24}" Click="OnExport" Margin="0,0,8,0" Padding="10,6" />
                <ui:Button Content="Reset" Icon="{ui:SymbolIcon ArrowCounterclockwise24}" Click="OnReset" Appearance="Secondary" Padding="10,6" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <TextBlock Text="Active bands:" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBlock x:Name="BandCountText" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />
            </StackPanel>
        </Grid>

        <!-- Main: Curve + Sliders -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="200" MinHeight="150" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Frequency Response Curve -->
            <Border Grid.Row="0" 
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Margin="0,0,0,8" Padding="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <!-- Y-axis labels -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Stretch">
                        <TextBlock Text="+12 dB" FontSize="9" Foreground="{DynamicResource TextFillColorTertiaryBrush}" HorizontalAlignment="Right" />
                        <TextBlock Text="+6 dB" FontSize="9" Foreground="{DynamicResource TextFillColorTertiaryBrush}" HorizontalAlignment="Right" />
                        <TextBlock Text="0 dB" FontSize="9" Foreground="{DynamicResource TextFillColorTertiaryBrush}" HorizontalAlignment="Right" />
                        <TextBlock Text="-6 dB" FontSize="9" Foreground="{DynamicResource TextFillColorTertiaryBrush}" HorizontalAlignment="Right" />
                        <TextBlock Text="-12 dB" FontSize="9" Foreground="{DynamicResource TextFillColorTertiaryBrush}" HorizontalAlignment="Right" />
                    </StackPanel>
                    <!-- Curve Canvas -->
                    <Canvas x:Name="CurveCanvas" Grid.Column="1" ClipToBounds="True"
                            SizeChanged="OnCanvasSizeChanged" Background="Transparent" />
                </Grid>
            </Border>

            <!-- Separator -->
            <Border Grid.Row="1" Height="1" Background="{DynamicResource CardStrokeColorDefaultBrush}" Margin="0,4,0,4" />

            <!-- EQ Band Sliders -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="BandsPanel" ItemContainerStyle="{x:Null}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="105" Margin="4" Padding="8,6"
                                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="8"
                                    AllowDrop="True"
                                    Drop="OnBandDrop" DragOver="OnBandDragOver" MouseLeftButtonDown="OnBandMouseDown">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!-- Band number + filter type -->
                                    <Grid Grid.Row="0" Margin="0,0,0,4">
                                        <TextBlock Text="{Binding Index, StringFormat='Band {0}'}"
                                                   FontSize="10" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                        <ToggleButton x:Name="BandEnabled" IsChecked="{Binding Enabled}"
                                                      HorizontalAlignment="Right" Width="16" Height="16"
                                                      Checked="OnBandEnabledChanged" Unchecked="OnBandEnabledChanged">
                                            <TextBlock Text="✓" FontSize="8" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </ToggleButton>
                                    </Grid>

                                    <!-- Frequency + Type selector -->
                                    <Grid Grid.Row="1" Margin="0,0,0,4">
                                        <TextBlock Text="{Binding FrequencyDisplay}"
                                                   FontSize="11" FontWeight="Bold"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                        <TextBlock Text="{Binding FilterTypeString}"
                                                   FontSize="9"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   HorizontalAlignment="Right" />
                                    </Grid>

                                    <!-- Vertical Slider -->
                                    <Slider Grid.Row="2"
                                            Minimum="-12" Maximum="12"
                                            Value="{Binding Gain}"
                                            Orientation="Vertical"
                                            VerticalAlignment="Stretch"
                                            Height="120"
                                            TickFrequency="1"
                                            IsSnapToTickEnabled="True"
                                            ValueChanged="OnBandSliderChanged" />

                                    <!-- Gain display -->
                                    <TextBlock Grid.Row="3"
                                               Text="{Binding GainDisplay}"
                                               FontSize="10" FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

                                    <!-- Q + Frequency input -->
                                    <Grid Grid.Row="4" Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <ui:NumberBox Grid.Column="0"
                                                      Tag="Freq"
                                                      Value="{Binding Frequency}"
                                                      Minimum="20" Maximum="20000"
                                                      SmallChange="10" LargeChange="100"
                                                      SpinButtonPlacementMode="Compact"
                                                      FontSize="9"
                                                      ValueChanged="OnBandParamChanged" />
                                        <ui:NumberBox Grid.Column="1"
                                                      Tag="Q"
                                                      Value="{Binding Q}"
                                                      Minimum="0.1" Maximum="20"
                                                      SmallChange="0.1" LargeChange="0.5"
                                                      SpinButtonPlacementMode="Compact"
                                                      FontSize="9" Width="50" Margin="4,0,0,0"
                                                      ValueChanged="OnBandParamChanged" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- Bottom: Preamp -->
        <Grid Grid.Row="2" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Preamp" FontSize="12" FontWeight="SemiBold"
                       VerticalAlignment="Center" Margin="0,0,12,0" />
            <Slider Grid.Column="1" x:Name="PreampSlider"
                    Minimum="-12" Maximum="0" Value="-6"
                    TickFrequency="0.5" IsSnapToTickEnabled="True"
                    ValueChanged="OnPreampChanged"
                    VerticalAlignment="Center" />
            <TextBlock Grid.Column="2" x:Name="PreampValueText"
                       Text="-6.0 dB" FontSize="12" FontWeight="SemiBold"
                       MinWidth="60" TextAlignment="Right"
                       VerticalAlignment="Center" />
        </Grid>
    </Grid>
</UserControl>
