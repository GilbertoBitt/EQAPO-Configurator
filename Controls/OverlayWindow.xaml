<Window x:Class="EQAPO_Configurator.Controls.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EQAPO Overlay"
        Width="220" Height="80"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Left="0" Top="0"
        Loaded="OnLoaded">

    <Grid Margin="8">
        <Border x:Name="OverlayBorder"
                Background="#AA101010"
                CornerRadius="8"
                Padding="10,8"
                BorderBrush="#33FFFFFF"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Status indicator -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
                    <Ellipse Width="6" Height="6"
                             Fill="#00CC66"
                             Margin="0,0,6,0"
                             VerticalAlignment="Center" />
                    <TextBlock x:Name="StatusText"
                               Text="EQ ACTIVE"
                               FontFamily="Segoe UI"
                               FontSize="10"
                               FontWeight="Bold"
                               Foreground="#00CC66"
                               VerticalAlignment="Center" />
                </StackPanel>

                <!-- Profile name -->
                <TextBlock x:Name="ProfileNameText"
                           Grid.Row="1"
                           Text="No Profile"
                           FontFamily="Segoe UI"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="#FFFFFF"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,0,0,2" />

                <!-- Genre / info -->
                <TextBlock x:Name="InfoText"
                           Grid.Row="2"
                           Text=""
                           FontFamily="Segoe UI"
                           FontSize="9"
                           Foreground="#888888"
                           TextTrimming="CharacterEllipsis" />
            </Grid>
        </Border>
    </Grid>
</Window>
