<UserControl x:Class="EQAPO_Configurator.Controls.SpectrumAnalyzer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="LIVE SPECTRUM" FontSize="10" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" VerticalAlignment="Center"/>

            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock x:Name="PeakText" Text="" FontSize="9" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="RmsText" Text="" FontSize="9" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Canvas x:Name="SpectrumCanvas" ClipToBounds="True"
                    SizeChanged="SpectrumCanvas_SizeChanged"/>

            <Canvas x:Name="EqOverlayCanvas" ClipToBounds="True" IsHitTestVisible="False"
                    Opacity="0.4"/>

            <Canvas x:Name="LabelsCanvas" ClipToBounds="True" IsHitTestVisible="False"/>
        </Grid>
    </Grid>
</UserControl>
